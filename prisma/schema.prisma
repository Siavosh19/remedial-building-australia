generator client {
  provider = "prisma-client-js"
}

// industry_news is managed by Supabase directly (not via Prisma mutations).
// This model declaration exists solely to prevent prisma db push from dropping the table.
model IndustryNews {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  slug            String    @unique
  summary         String?
  industry_impact String?
  category        String?
  tags            String[]
  source_name     String?
  source_url      String?
  published_date  DateTime?
  featured_image  String?
  status          String?   @default("published")
  priority        Int?      @default(2)
  include_in_newsletter Boolean @default(false)
  newsletter_sent_at DateTime?
  created_at      DateTime? @default(now())

  @@map("industry_news")
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CompanyStatus {
  draft
  published
  needs_review
  rejected
}

enum ProfileStatus {
  basic
  contact_verified
  business_verified
  licence_verified
  practitioner_verified
  claimed
  featured
}

enum LocationState {
  NSW
  VIC
  QLD
  WA
  SA
  TAS
  ACT
  NT
}

enum LicenceStatus {
  verified
  needs_review
  unverified
  expired
}

enum TagType {
  service
  defect
  repair_system
  capability
}

enum UserRole {
  company_owner
  admin
  staff
  super_admin
  content_admin
  supplier_manager
  read_only_admin
  supplier_user
  ai_scope_user
  newsletter_subscriber
  client_user
}

enum AccountType {
  newsletter_subscriber
  directory_user
  supplier_user
  ai_scope_user
  strata_client
}

// ── Strata / client quote-request platform ───────────────────────────────────
enum ClientType {
  strata_manager
  owners_corp_rep
  building_manager
  property_owner
  consultant
  other
}

enum PropertyType {
  residential_strata
  commercial_strata
  mixed_use
  residential_house
  commercial_building
  other
}

enum ClientQuoteStatus {
  draft
  submitted
  sent_to_businesses
  responses_received
  closed
}

enum ContractorResponseStatus {
  pending
  contacted
  quoted
  declined
  not_suitable
}

enum QuoteEmailStatus {
  pending
  sent
  failed
}

enum SupplierStatus {
  active
  draft
  hidden
  suspended
}

enum ProductStatus {
  draft
  needs_review
  checked
  published
  outdated_tds
  hidden
}

enum PromotionTier {
  basic
  promoted
  premium
  hidden
}

enum PromotionStatus {
  pending
  active
  expired
  cancelled
  trial
}

enum PaymentStatus {
  unpaid
  paid
  overdue
  failed
  trial
  cancelled
}

enum RequestStatus {
  pending
  approved
  rejected
  needs_info
  cancelled
}

enum AIScopeUserStatus {
  pending
  approved
  trial
  active
  cancelled
  disabled
}

enum AnalyticsEventType {
  product_impression
  product_click
  tds_click
  sds_click
  website_click
  selector_appearance
  ai_scope_appearance
  directory_profile_view
  directory_contact_click
  promotion_impression
  promotion_click
}

enum CompanyUserRole {
  owner
  manager
  staff
}

enum LeadPlan {
  free
  starter
  professional
  premium
}

enum LeadType {
  service_request
  quote_request
  enquiry
}

enum LeadStatus {
  new
  sent
  viewed
  accepted
  declined
  expired
}

enum LeadResponseStatus {
  pending
  accepted
  declined
  no_response
}

enum AdminReviewStatus {
  discovered
  possible_match
  verified
  needs_review
  rejected
  published
  needs_recheck
}

enum DirectoryPlanType {
  basic
  claimed
  featured
  business
  premium
}

enum DirectoryClaimStatus {
  unclaimed
  claim_pending
  claimed
  rejected
}

enum DirectorySubStatus {
  none
  trialing
  active
  past_due
  cancelled
  expired
}

enum DirectoryBillingCycle {
  free
  monthly
  yearly
}

enum QuoteRequestStatus {
  new
  viewed
  responded
  not_suitable
  won
  lost
}

enum QuoteRequestRole {
  strata_manager
  committee_member
  building_manager
  consultant
  builder
  owner
  other
}

enum LeadUrgency {
  emergency
  within_week
  within_month
  planning
}

model Company {
  id                  Int           @id @default(autoincrement())
  slug                String        @unique
  name                String
  abn                 String?
  website             String?
  phone               String?
  email               String
  google_business_url String?
  facebook_url        String?
  instagram_url       String?
  linkedin_url        String?
  description         String?
  full_description    String?
  tagline             String?
  services_offered    String?
  year_established    Int?
  main_category_id    Int?
  status              CompanyStatus @default(draft)
  profile_status      ProfileStatus @default(basic)
  confidence_score    Int           @default(0)
  is_claimed          Boolean       @default(false)
  is_featured         Boolean       @default(false)
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  // ── New plan / claim / subscription fields ───────────────────────────────
  plan_type              DirectoryPlanType    @default(basic)
  listing_claim_status   DirectoryClaimStatus @default(unclaimed)
  logo_url               String?
  quote_requests_enabled Boolean              @default(false)
  claimed_at             DateTime?
  featured_until         DateTime?
  licence_number         String?
  licence_type           String?
  insurance_details      String?
  profile_views          Int                  @default(0)
  website_clicks         Int                  @default(0)
  phone_clicks           Int                  @default(0)
  suspended              Boolean              @default(false)

  main_category          Category?              @relation("CompanyMainCategory", fields: [main_category_id], references: [id])
  locations              Location[]
  company_categories     CompanyCategory[]
  licences               Licence[]
  company_tags           CompanyTag[]
  users                  CompanyUser[]
  lead_subscriptions     LeadSubscription[]
  lead_deliveries        LeadDelivery[]
  admin_review_queue     AdminReviewQueue[]
  directory_subscription DirectorySubscription?
  claim_requests         ClaimRequest[]
  quote_requests         QuoteRequest[]
  quote_request_deliveries QuoteRequestDelivery[]
  media                  CompanyMedia[]

  @@index([status])
  @@index([is_featured])
  @@index([confidence_score])
  @@index([is_claimed])
  @@index([name])
  @@index([plan_type])
  @@index([listing_claim_status])
  @@index([main_category_id])
  // NOTE: directory search also relies on pg_trgm GIN indexes on companies.name
  // and companies.description (for ILIKE keyword/IDF matching). Prisma can't model
  // trigram GIN indexes without the postgresqlExtensions preview, so they are
  // created in migration 20260714120000_search_trgm_indexes. Do NOT let a
  // `prisma migrate dev` drop them.
  @@map("companies")
}

model Location {
  id                  Int             @id @default(autoincrement())
  company_id          Int
  address             String
  suburb              String?
  city                String?
  state               LocationState
  postcode            String
  latitude            Float?
  longitude           Float?
  service_radius_km   Int?
  services_statewide  Boolean         @default(false)
  services_nationwide Boolean         @default(false)
  states_serviced     LocationState[]

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([latitude])
  @@index([longitude])
  @@index([state])
  @@index([postcode])
  @@map("locations")
}

model Category {
  id            Int     @id @default(autoincrement())
  name          String
  slug          String  @unique
  description   String?
  parent_id     Int?
  display_order Int     @default(0)
  icon          String?
  is_active     Boolean @default(true)

  parent              Category?         @relation("CategoryParent", fields: [parent_id], references: [id])
  children            Category[]        @relation("CategoryParent")
  companies           Company[]         @relation("CompanyMainCategory")
  company_categories  CompanyCategory[]
  leads               Lead[]            @relation("LeadCategory")
  sub_leads           Lead[]            @relation("LeadSubcategory")
  directory_leads     DirectoryLead[]   @relation("DirectoryLeadCategory")
  directory_sub_leads DirectoryLead[]   @relation("DirectoryLeadSubcategory")
  client_quote_requests     ClientQuoteRequest[] @relation("ClientQuoteCategory")
  client_quote_subrequests  ClientQuoteRequest[] @relation("ClientQuoteSubcategory")

  @@map("categories")
}

model CompanyCategory {
  id          Int       @id @default(autoincrement())
  company_id  Int
  category_id Int
  is_primary  Boolean   @default(false)
  is_approved Boolean   @default(false)
  approved_at DateTime?
  approved_by Int?

  company    Company  @relation(fields: [company_id], references: [id])
  category   Category @relation(fields: [category_id], references: [id])
  approvedBy User?    @relation("CompanyCategoryApprover", fields: [approved_by], references: [id])

  @@index([company_id])
  @@index([category_id])
  @@index([is_approved, category_id])
  @@map("company_categories")
}

model Licence {
  id                      Int           @id @default(autoincrement())
  company_id              Int
  licence_number          String
  licence_class           String?
  licence_authority       String?
  licence_state           String?
  verification_source_url String?
  verification_date       DateTime?
  last_checked_date       DateTime?
  status                  LicenceStatus @default(needs_review)

  company Company @relation(fields: [company_id], references: [id])

  @@map("licences")
}

model Tag {
  id       Int     @id @default(autoincrement())
  name     String
  slug     String  @unique
  tag_type TagType

  company_tags CompanyTag[]

  @@map("tags")
}

model CompanyTag {
  id          Int     @id @default(autoincrement())
  company_id  Int
  tag_id      Int
  is_approved Boolean @default(false)

  company Company @relation(fields: [company_id], references: [id])
  tag     Tag     @relation(fields: [tag_id], references: [id])

  @@map("company_tags")
}

model User {
  id                Int          @id @default(autoincrement())
  email             String       @unique
  password_hash     String
  full_name         String?
  phone             String?
  role              UserRole
  account_type      AccountType?
  supplier_id       Int?
  is_verified       Boolean      @default(false)
  suspended         Boolean      @default(false)
  email_verified_at DateTime?
  terms_accepted_at DateTime?
  terms_version     String?
  last_login_at     DateTime?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  company_users               CompanyUser[]
  approved_company_categories CompanyCategory[]  @relation("CompanyCategoryApprover")
  review_queue                AdminReviewQueue[] @relation("AdminReviewQueueReviewer")
  supplier                    Supplier?          @relation(fields: [supplier_id], references: [id])
  audit_logs                  AuditLog[]         @relation("AuditLogActor")
  ai_scope_user               AIScopeUser?
  client_profile              ClientProfile?
  client_quote_requests       ClientQuoteRequest[]
  jobs                        Job[]
  job_payments                JobPayment[]
  notifications               Notification[]
  push_subscriptions          PushSubscription[]

  @@index([account_type])
  @@index([supplier_id])
  @@map("users")
}

// Web Push subscriptions (one per browser/device per user). Populated when a
// logged-in user grants notification permission; used to fan out OS-level push
// alongside the in-app Notification rows. Expired endpoints (404/410) are pruned.
model PushSubscription {
  id         Int      @id @default(autoincrement())
  user_id    Int
  endpoint   String   @unique
  p256dh     String
  auth       String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("push_subscriptions")
}

// In-app notification bell. One row per recipient user per event. Complements the
// existing Resend emails (leads, applicants) — it does not replace them.
model Notification {
  id         Int       @id @default(autoincrement())
  user_id    Int
  type       String    // "lead" | "lead_updated" | "job_applicant"
  title      String
  body       String?
  link       String?
  read_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read_at])
  @@index([user_id, created_at])
  @@map("notifications")
}

model CompanyUser {
  id          Int             @id @default(autoincrement())
  company_id  Int
  user_id     Int
  role        CompanyUserRole
  is_primary  Boolean         @default(false)
  invited_at  DateTime?
  accepted_at DateTime?

  company Company @relation(fields: [company_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@map("company_users")
}

model LeadSubscription {
  id                        Int             @id @default(autoincrement())
  company_id                Int
  is_active                 Boolean         @default(false)
  plan                      LeadPlan        @default(free)
  categories_subscribed     Int[]
  states_subscribed         LocationState[]
  radius_km                 Int?
  max_leads_per_month       Int?
  leads_received_this_month Int?            @default(0)
  subscription_start        DateTime?
  subscription_end          DateTime?
  created_at                DateTime        @default(now())
  updated_at                DateTime        @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@map("lead_subscriptions")
}

model Lead {
  id                 Int           @id @default(autoincrement())
  lead_type          LeadType
  status             LeadStatus    @default(new)
  submitted_by_name  String
  submitted_by_email String
  submitted_by_phone String?
  postcode           String
  suburb             String?
  state              LocationState
  category_id        Int?
  subcategory_id     Int?
  description        String?
  urgency            LeadUrgency
  budget_range       String?
  created_at         DateTime      @default(now())
  expires_at         DateTime?

  category    Category?      @relation("LeadCategory", fields: [category_id], references: [id])
  subcategory Category?      @relation("LeadSubcategory", fields: [subcategory_id], references: [id])
  deliveries  LeadDelivery[]

  @@index([status])
  @@index([category_id])
  @@index([state])
  @@index([created_at])
  @@map("leads")
}

model LeadDelivery {
  id              Int                @id @default(autoincrement())
  lead_id         Int
  company_id      Int
  delivered_at    DateTime           @default(now())
  opened_at       DateTime?
  response_status LeadResponseStatus @default(pending)
  responded_at    DateTime?

  lead    Lead    @relation(fields: [lead_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@index([lead_id])
  @@index([company_id])
  @@index([response_status])
  @@map("lead_deliveries")
}

model AdminReviewQueue {
  id          Int               @id @default(autoincrement())
  company_id  Int
  status      AdminReviewStatus
  source      String?
  notes       String?
  reviewed_by Int?
  reviewed_at DateTime?
  created_at  DateTime          @default(now())

  company  Company @relation(fields: [company_id], references: [id])
  reviewer User?   @relation("AdminReviewQueueReviewer", fields: [reviewed_by], references: [id])

  @@map("admin_review_queue")
}

model DirectoryLead {
  id                            Int            @id @default(autoincrement())
  google_place_id               String         @unique
  business_name                 String
  phone                         String?
  website                       String?
  email                         String?
  address                       String?
  suburb                        String?
  state                         LocationState?
  postcode                      String?
  latitude                      Float?
  longitude                     Float?
  google_maps_url               String?
  google_rating                 Float?
  google_review_count           Int?
  category_id                   Int?
  subcategory_id                Int?
  category_name                 String?
  subcategory_name              String?
  search_query                  String?
  status                        String         @default("unverified")
  approved_for_public_directory Boolean        @default(false)
  website_scraped               Boolean        @default(false)
  website_scrape_error          String?
  notes                         String?
  collected_at                  DateTime       @default(now())
  updated_at                    DateTime       @updatedAt

  category    Category? @relation("DirectoryLeadCategory", fields: [category_id], references: [id])
  subcategory Category? @relation("DirectoryLeadSubcategory", fields: [subcategory_id], references: [id])

  @@index([status])
  @@index([category_id])
  @@index([subcategory_id])
  @@index([state])
  @@index([collected_at])
  @@map("directory_leads")
}

// ── Directory Subscription ────────────────────────────────────────────────────

model DirectorySubscription {
  id                     Int                   @id @default(autoincrement())
  company_id             Int                   @unique
  plan_type              DirectoryPlanType     @default(basic)
  billing_cycle          DirectoryBillingCycle @default(free)
  subscription_status    DirectorySubStatus    @default(none)
  stripe_customer_id     String?
  stripe_subscription_id String?
  trial_started_at       DateTime?
  trial_ends_at          DateTime?
  current_period_start   DateTime?
  current_period_end     DateTime?
  cancel_at_period_end   Boolean               @default(false)
  cancelled_at           DateTime?
  admin_override_plan    DirectoryPlanType?
  admin_override_by      Int?
  admin_override_at      DateTime?
  admin_notes            String?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@index([subscription_status])
  @@index([plan_type])
  @@map("directory_subscriptions")
}

// Admin-managed billing plans across every product line (directory listings, AI
// Scope Reader, supplier cards, …). The admin "Plans & Pricing" screen is the
// single source of truth; checkout reads the Stripe price id from here, not env.
model Plan {
  id                Int      @id @default(autoincrement())
  product_line      String   // "directory" | "ai_scope" | "supplier_card"
  tier              String   // "claimed" | "featured" | … (free-form per product line)
  name              String
  description       String?
  billing_interval  String   // "month" | "year" | "one_time"
  amount_cents      Int      // price actually charged (founding price when on offer)
  compare_at_cents  Int?     // standard price, shown struck-through when on offer
  promo_label       String?  // e.g. "Limited time" — shown beside the offer price
  currency          String   @default("aud")
  trial_days        Int      @default(0)
  features          String[] // bullet points shown on the pricing card
  stripe_product_id String?
  stripe_price_id   String?  // the live Stripe price used at checkout (founding)
  standard_stripe_price_id String? // Stripe price for the standard (compare-at) amount
  is_active         Boolean  @default(true)
  is_public         Boolean  @default(true) // show on the public pricing page
  display_order     Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([product_line])
  @@index([is_active])
  @@map("plans")
}

// ── Claim Requests ────────────────────────────────────────────────────────────

model ClaimRequest {
  id             Int                  @id @default(autoincrement())
  company_id     Int
  user_id        Int
  status         DirectoryClaimStatus @default(claim_pending)
  claimant_name  String
  claimant_email String
  claimant_phone String?
  notes          String?
  admin_notes    String?
  reviewed_by    Int?
  reviewed_at    DateTime?
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([status])
  @@index([user_id])
  @@map("claim_requests")
}

// ── Quote Requests ────────────────────────────────────────────────────────────

model QuoteRequest {
  id                Int                @id @default(autoincrement())
  company_id        Int
  requester_name    String
  requester_email   String
  requester_phone   String?
  requester_role    QuoteRequestRole?
  building_suburb   String?
  project_category  String?
  urgency           String?
  budget_range      String?
  message           String?
  status            QuoteRequestStatus @default(new)
  notified_business Boolean            @default(false)
  notified_admin    Boolean            @default(false)
  responded_at      DateTime?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([status])
  @@index([created_at])
  @@map("quote_requests")
}

// ── Strata / Client Quote-Request Platform ───────────────────────────────────
// A separate, additive platform layered on top of the directory. Clients submit
// one broadcast request; it is matched to paid (Premium / Premium Plus) listings
// and fanned out as QuoteRequestDelivery rows. The directory itself is untouched.

model ClientProfile {
  id           Int        @id @default(autoincrement())
  user_id      Int        @unique
  client_type  ClientType
  company_name String?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("client_profiles")
}

model ClientQuoteRequest {
  id                        Int               @id @default(autoincrement())
  client_user_id            Int
  contact_name              String
  contact_email             String
  contact_phone             String?
  company_name              String?
  building_address          String
  suburb                    String
  postcode                  String
  state                     LocationState?
  strata_plan_number        String?
  property_type             PropertyType
  work_category_id          Int
  work_subcategory_id       Int?
  description               String
  urgency                   LeadUrgency
  preferred_inspection      String?
  consultant_scope_available Boolean          @default(false)
  budget_range              String?
  terms_accepted            Boolean           @default(false)
  terms_version             String?
  accepted_at               DateTime?
  status                    ClientQuoteStatus @default(draft)
  matched_count             Int               @default(0)
  latitude                  Float?
  longitude                 Float?
  created_at                DateTime          @default(now())
  updated_at                DateTime          @updatedAt
  submitted_at              DateTime?
  closed_at                 DateTime?

  client        User                   @relation(fields: [client_user_id], references: [id])
  work_category Category               @relation("ClientQuoteCategory", fields: [work_category_id], references: [id])
  subcategory   Category?              @relation("ClientQuoteSubcategory", fields: [work_subcategory_id], references: [id])
  deliveries    QuoteRequestDelivery[]
  files         QuoteRequestFile[]

  @@index([client_user_id])
  @@index([status])
  @@index([work_category_id])
  @@index([created_at])
  @@map("client_quote_requests")
}

model QuoteRequestDelivery {
  id              Int                      @id @default(autoincrement())
  request_id      Int
  company_id      Int
  rank_tier       Int                      @default(0)
  email_status    QuoteEmailStatus         @default(pending)
  email_sent_at   DateTime?
  email_error     String?
  opened_at       DateTime?
  response_status ContractorResponseStatus @default(pending)
  responded_at    DateTime?
  quote_doc_url   String?
  notes           String?
  created_at      DateTime                 @default(now())
  updated_at      DateTime                 @updatedAt

  request ClientQuoteRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  company Company            @relation(fields: [company_id], references: [id])

  @@unique([request_id, company_id])
  @@index([request_id])
  @@index([company_id])
  @@index([response_status])
  @@map("quote_request_deliveries")
}

model QuoteRequestFile {
  id           Int      @id @default(autoincrement())
  request_id   Int
  file_type    String // "photo" | "report" | "drawing" | "document"
  url          String
  filename     String?
  size_bytes   Int?
  content_type String?
  uploaded_by  String   @default("client") // "client" | "business"
  created_at   DateTime @default(now())

  request ClientQuoteRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@index([request_id])
  @@map("quote_request_files")
}

// ── Company Media ─────────────────────────────────────────────────────────────

model CompanyMedia {
  id         Int      @id @default(autoincrement())
  company_id Int
  media_type String // "logo" | "photo"
  url        String
  filename   String?
  size_bytes Int?
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([media_type])
  @@map("company_media")
}

// ── Supplier / Brand ─────────────────────────────────────────────────────────

model Supplier {
  id                 Int            @id @default(autoincrement())
  slug               String         @unique
  brand_name         String
  logo_url           String?
  website            String?
  australian_website String?
  contact_name       String?
  contact_email      String?
  contact_phone      String?
  billing_email      String?
  status             SupplierStatus @default(draft)
  abn                String?
  supplier_type      String?
  product_categories String[]
  service_areas      String[]
  signup_reason      String?
  signup_notes       String?
  supplier_notes     String?
  admin_notes        String?
  stripe_customer_id String?
  current_plan       String?
  payment_status     PaymentStatus  @default(unpaid)
  terms_accepted_at  DateTime?
  terms_version      String?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  users           User[]
  products        SupplierProduct[]
  update_requests SupplierUpdateRequest[]
  audit_logs      AuditLog[]              @relation("AuditLogSupplier")

  @@index([status])
  @@index([slug])
  @@map("suppliers")
}

model SupplierProduct {
  id                            Int             @id @default(autoincrement())
  supplier_id                   Int
  slug                          String          @unique
  product_name                  String
  product_category              String?
  repair_system_pages           String[]
  application_tags              String[]
  substrate_tags                String[]
  tds_url                       String?
  sds_url                       String?
  product_url                   String?
  status                        ProductStatus   @default(draft)
  promotion_tier                PromotionTier   @default(basic)
  promotion_status              PromotionStatus @default(pending)
  promotion_start_date          DateTime?
  promotion_end_date            DateTime?
  renewal_date                  DateTime?
  monthly_fee                   Decimal?        @db.Decimal(10, 2)
  payment_status                PaymentStatus   @default(unpaid)
  stripe_subscription_id        String?
  stripe_price_id               String?
  stripe_customer_id            String?
  stripe_current_period_start   DateTime?
  stripe_current_period_end     DateTime?
  stripe_cancel_at_period_end   Boolean         @default(false)
  stripe_latest_invoice_status  String?
  show_between_product_cards    Boolean         @default(false)
  show_recommended_badge        Boolean         @default(false)
  promote_on_repair_system_page Boolean         @default(false)
  promote_in_system_selector    Boolean         @default(false)
  promote_in_ai_scope_writer    Boolean         @default(false)
  category_sponsor              Boolean         @default(false)
  priority_order                Int             @default(0)
  admin_notes                   String?
  supplier_notes                String?
  last_checked_at               DateTime?
  last_updated_at               DateTime?
  created_at                    DateTime        @default(now())
  updated_at                    DateTime        @updatedAt

  supplier           Supplier                @relation(fields: [supplier_id], references: [id])
  analytics_events   ProductAnalyticsEvent[]
  update_requests    ProductUpdateRequest[]
  promotion_requests PromotionRequest[]
  audit_logs         AuditLog[]              @relation("AuditLogProduct")

  @@index([supplier_id])
  @@index([status])
  @@index([promotion_status])
  @@index([payment_status])
  @@index([promotion_tier])
  @@map("supplier_products")
}

// ── Analytics ────────────────────────────────────────────────────────────────

model ProductAnalyticsEvent {
  id                 Int                @id @default(autoincrement())
  product_id         Int?
  supplier_id        Int?
  event_type         AnalyticsEventType
  repair_system_page String?
  session_id         String?
  ip_hash            String?
  user_agent         String?
  referrer           String?
  created_at         DateTime           @default(now())

  product SupplierProduct? @relation(fields: [product_id], references: [id])

  @@index([product_id])
  @@index([supplier_id])
  @@index([event_type])
  @@index([created_at])
  @@map("product_analytics_events")
}

// ── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             Int      @id @default(autoincrement())
  actor_id       Int?
  actor_email    String?
  actor_role     String?
  entity_type    String
  entity_id      String?
  action         String
  previous_value Json?
  new_value      Json?
  ip_address     String?
  user_agent     String?
  supplier_id    Int?
  created_at     DateTime @default(now())

  product_id Int?
  actor      User?            @relation("AuditLogActor", fields: [actor_id], references: [id])
  supplier   Supplier?        @relation("AuditLogSupplier", fields: [supplier_id], references: [id])
  product    SupplierProduct? @relation("AuditLogProduct", fields: [product_id], references: [id])

  @@index([actor_id])
  @@index([entity_type])
  @@index([created_at])
  @@index([supplier_id])
  @@index([product_id])
  @@map("audit_logs")
}

// ── AI Scope Writer Users ─────────────────────────────────────────────────────

model AIScopeUser {
  id             Int               @id @default(autoincrement())
