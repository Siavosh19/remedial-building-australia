  status         AIScopeUserStatus @default(pending)
  plan_type      String?
  company        String?
  job_role       String?
  notes          String?
  scopes_created Int               @default(0)
  trial_ends_at  DateTime?
  approved_at    DateTime?
  approved_by    Int?
  disabled_at    DateTime?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@index([status])
  @@map("ai_scope_users")
}

// ── Supplier Update Requests ──────────────────────────────────────────────────

model SupplierUpdateRequest {
